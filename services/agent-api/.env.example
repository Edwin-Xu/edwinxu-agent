AGENT_DB_PATH=../../data/sqlite/agent.db
AGENT_TRACE_DIR=../../artifacts/traces
AGENT_API_BASE_URL=http://localhost:8080

# Optional: enable real model
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

# HTTP timeout for model calls
API_TIMEOUT_MS=300000

# Optional: web search tool provider
# - WEB_SEARCH_PROVIDER=duckduckgo (no key required, best-effort HTML parse)
# - WEB_SEARCH_PROVIDER=serper (requires SERPER_API_KEY)
WEB_SEARCH_PROVIDER=duckduckgo
SERPER_API_KEY=
